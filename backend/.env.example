# ─── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string (run: docker compose up -d db)
DATABASE_URL=postgresql+psycopg://chessmaster:chessmaster@localhost:5432/chessmaster

# Secret used to sign JWT tokens and verification/reset tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_DEV_ONLY

# Anthropic API key — required for AI coaching reports
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email delivery (optional) ─────────────────────────────────────────────────
# When RESEND_API_KEY is not set, verification / password-reset tokens are
# printed to server stdout (safe for local development).

RESEND_API_KEY=re_...
EMAIL_FROM=ChessMaster <noreply@yourdomain.com>

# Base URL used to build links in outgoing emails
FRONTEND_URL=http://localhost:3000

# ─── Optional / advanced ───────────────────────────────────────────────────────

# CORS — space-separated list of allowed frontend origins (default: localhost:3000)
# CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# JWT lifetime in seconds (default: 3600)
# ACCESS_TOKEN_LIFETIME=3600

# Set to true and update cookie_samesite to "none" for cross-origin prod deployments
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax

# ─── Stockfish (no longer used at request time) ────────────────────────────────
# Analysis now runs client-side via Stockfish WASM in the browser.
# These vars are only read for the /api/health endpoint response.

# STOCKFISH_PATH=stockfish/stockfish/stockfish-windows-x86-64-avx2.exe
# STOCKFISH_DEPTH=20
